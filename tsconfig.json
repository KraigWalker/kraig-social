{
  "include": ["oxfmt.config.ts", "oxlint.config.ts"],
  "compilerOptions": {
    "lib": ["ES2022"],
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "paths": {
      "oxfmt": ["./common/autoinstallers/oxc-autoinstaller/node_modules/oxfmt"],
      "oxlint": ["./common/autoinstallers/oxc-autoinstaller/node_modules/oxlint"]
    }
  }
}
