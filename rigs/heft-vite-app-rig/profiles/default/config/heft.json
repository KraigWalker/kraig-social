{
  "$schema": "https://developer.microsoft.com/json-schemas/heft/v0/heft.schema.json",
  "extends": "@kraigwalker/heft-base-rig/profiles/default/config/heft.json",
  "phasesByName": {
    "build": {
      "phaseDescription": "Build the React Router application.",
      "cleanFiles": [{ "sourcePath": "dist" }],
      "tasksByName": {
        "react-router-build": {
          "taskPlugin": {
            "pluginPackage": "@rushstack/heft",
            "pluginName": "run-script-plugin",
            "options": {
              "scriptPath": "node_modules/@kraigwalker/heft-toolchain/scripts/heft-task.cjs",
              "scriptOptions": {
                "tool": "react-router-build"
              }
            }
          }
        }
      }
    },
    "typecheck": {
      "phaseDescription": "Generate React Router types and typecheck with tsgo.",
      "tasksByName": {
        "react-router-typegen": {
          "taskPlugin": {
            "pluginPackage": "@rushstack/heft",
            "pluginName": "run-script-plugin",
            "options": {
              "scriptPath": "node_modules/@kraigwalker/heft-toolchain/scripts/heft-task.cjs",
              "scriptOptions": {
                "tool": "react-router-typegen"
              }
            }
          }
        },
        "tsgo": {
          "taskDependencies": ["react-router-typegen"],
          "taskPlugin": {
            "pluginPackage": "@rushstack/heft",
            "pluginName": "run-script-plugin",
            "options": {
              "scriptPath": "node_modules/@kraigwalker/heft-toolchain/scripts/heft-task.cjs",
              "scriptOptions": {
                "tool": "tsgo-check"
              }
            }
          }
        }
      }
    }
  }
}
