{
  "name": "@kraigwalker/cms-api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:migrate:prod": "node dist/migrate.js"
  },
  "dependencies": {
    "@fastify/cors": "11.2.0",
    "@fastify/helmet": "13.0.2",
    "@fastify/sensible": "6.0.4",
    "better-auth": "1.6.13",
    "drizzle-orm": "0.45.2",
    "fastify": "5.8.5",
    "pg": "8.21.0",
    "pino-pretty": "13.1.3",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/pg": "8.20.0",
    "@types/node": "^24.0.0",
    "drizzle-kit": "0.31.10",
    "tsx": "4.22.4",
    "typescript": "6.0.3"
  }
}
