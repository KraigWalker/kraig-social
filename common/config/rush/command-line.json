/**
 * This configuration file defines custom commands for the "rush" command-line.
 * More documentation is available on the Rush website: https://rushjs.io
 */
{
  "$schema": "https://developer.microsoft.com/json-schemas/rush/v5/command-line.schema.json",

  "commands": [
    {
      "commandKind": "phased",
      "name": "build",
      "summary": "Build production artifacts.",
      "description": "Build production artifacts for selected projects using their Heft rig.",
      "safeForSimultaneousRushProcesses": false,
      "enableParallelism": true,
      "allowOversubscription": true,
      "incremental": true,
      "phases": ["_phase:build"]
    },
    {
      "commandKind": "phased",
      "name": "verify",
      "summary": "Run typecheck and lint phases.",
      "description": "Run typecheck and lint phases for selected projects using their Heft rig.",
      "safeForSimultaneousRushProcesses": false,
      "enableParallelism": true,
      "allowOversubscription": true,
      "incremental": true,
      "phases": ["_phase:typecheck", "_phase:lint"]
    },
    {
      "commandKind": "phased",
      "name": "format",
      "summary": "Check formatting.",
      "description": "Check project formatting with Oxfmt.",
      "safeForSimultaneousRushProcesses": false,
      "enableParallelism": true,
      "allowOversubscription": true,
      "incremental": true,
      "phases": ["_phase:format"]
    },
    {
      "commandKind": "phased",
      "name": "fix",
      "summary": "Apply lint fixes and formatting.",
      "description": "Apply OXC lint fixes and formatting for local development.",
      "safeForSimultaneousRushProcesses": false,
      "enableParallelism": true,
      "allowOversubscription": true,
      "incremental": false,
      "phases": ["_phase:fix"]
    }
  ],

  "phases": [
    {
      "name": "_phase:build",
      "dependencies": {
        "upstream": ["_phase:build"]
      },
      "missingScriptBehavior": "silent"
    },
    {
      "name": "_phase:typecheck",
      "dependencies": {
        "upstream": ["_phase:build"]
      },
      "missingScriptBehavior": "silent"
    },
    {
      "name": "_phase:lint",
      "dependencies": {
        "self": ["_phase:typecheck"]
      },
      "missingScriptBehavior": "silent"
    },
    {
      "name": "_phase:format",
      "missingScriptBehavior": "silent"
    },
    {
      "name": "_phase:fix",
      "missingScriptBehavior": "silent"
    }
  ],

  "parameters": []
}
