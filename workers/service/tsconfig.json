{
  "include": ["src/**/*.ts", "vite.config.ts", "eslint.config.js"],
  "compilerOptions": {
    "lib": ["ES2022", "WebWorker"],
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true
  }
}
