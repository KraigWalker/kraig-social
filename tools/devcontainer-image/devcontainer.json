{
  "name": "kraig-social dev container image",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "."
  },
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": "true",
      "username": "node",
      "upgradePackages": "true"
    },
    "ghcr.io/devcontainers/features/node:2.1.0": {
      "version": "none"
    },
    "ghcr.io/devcontainers/features/git:1": {
      "version": "latest",
      "ppa": "false"
    }
  },
  "remoteUser": "node",
  "updateRemoteUserUID": true,
  "containerEnv": {
    "NPM_CONFIG_CACHE": "/home/node/.npm",
    "RUSH_PNPM_STORE_PATH": "/home/node/.pnpm-store"
  },
  "mounts": [
    "source=kraig-social-npm-cache,target=/home/node/.npm,type=volume",
    "source=kraig-social-pnpm-store,target=/home/node/.pnpm-store,type=volume",
    "source=kraig-social-rush-home,target=/home/node/.rush,type=volume"
  ],
  "postCreateCommand": "rush install --subspace default && rush install-autoinstaller --name oxc-autoinstaller",
  "forwardPorts": [5173, 3000, 3001],
  "portsAttributes": {
    "5173": {
      "label": "kraig-social dev server",
      "onAutoForward": "notify"
    },
    "3000": {
      "label": "kraig-social production-like server",
      "onAutoForward": "silent"
    },
    "3001": {
      "label": "kraig-social gateway",
      "onAutoForward": "silent"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": ["openai.chatgpt", "ms-azuretools.vscode-docker", "oxc.oxc-vscode"],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "zsh",
        "editor.defaultFormatter": "oxc.oxc-vscode",
        "editor.formatOnSave": true,
        "editor.tabSize": 2,
        "oxc.fmt.configPath": "oxfmt.config.ts",
        "oxc.path.oxfmt": "common/autoinstallers/oxc-autoinstaller/node_modules/.bin/oxfmt",
        "oxc.path.oxlint": "common/autoinstallers/oxc-autoinstaller/node_modules/.bin/oxlint",
        "oxc.path.tsgolint": "common/autoinstallers/oxc-autoinstaller/node_modules/.bin/tsgolint",
        "oxc.useExecPath": false,
        "[json]": {
          "editor.defaultFormatter": "oxc.oxc-vscode"
        },
        "[jsonc]": {
          "editor.defaultFormatter": "oxc.oxc-vscode"
        },
        "[javascript]": {
          "editor.defaultFormatter": "oxc.oxc-vscode"
        },
        "[javascriptreact]": {
          "editor.defaultFormatter": "oxc.oxc-vscode"
        },
        "[typescript]": {
          "editor.defaultFormatter": "oxc.oxc-vscode"
        },
        "[typescriptreact]": {
          "editor.defaultFormatter": "oxc.oxc-vscode"
        }
      },
      "mcp": {
        "servers": {
          "rush-mcp-server": {
            "type": "stdio",
            "command": "npx",
            "args": ["-y", "@rushstack/mcp-server@0.4.17", "${containerWorkspaceFolder}"]
          }
        }
      }
    }
  }
}
